<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="dual_track_arch" name="双轨计算架构">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1050" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        
        <mxCell id="title" value="双轨计算架构：AI推理与传统计算的解耦范式&lt;br&gt;Dual-Track Computing Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="1000" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="track_ai" value="轨道一：AI推理轨（独立封装模块）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=3;verticalAlign=top;align=center;spacingTop=10;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="600" height="520" as="geometry" />
        </mxCell>

        
        <mxCell id="ai_internal_label" value="内部带宽 &gt; 1TB/s（全闭环）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#6c8ebf;" vertex="1" parent="track_ai">
          <mxGeometry x="350" y="40" width="220" height="20" as="geometry" />
        </mxCell>

        
        <mxCell id="hbs" value="HBS（高带宽SRAM）&lt;br&gt;读写速度快1000倍 | 1600GB" style="step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;horizontal=0;size=20;" vertex="1" parent="track_ai">
          <mxGeometry x="40" y="60" width="500" height="55" as="geometry" />
        </mxCell>

        
        <mxCell id="hbf" value="HBF（高带宽Flash）&lt;br&gt;NAND垂直堆叠 | 容量为DRAM 10倍 | 冷数据仓储" style="step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;horizontal=0;size=20;" vertex="1" parent="track_ai">
          <mxGeometry x="40" y="125" width="500" height="55" as="geometry" />
        </mxCell>

        
        <mxCell id="hbm" value="HBM（高带宽DRAM）&lt;br&gt;模型权重 + KV缓存 | AI热数据主存" style="step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;horizontal=0;size=20;" vertex="1" parent="track_ai">
          <mxGeometry x="40" y="190" width="500" height="55" as="geometry" />
        </mxCell>

        
        <mxCell id="ai_compute" value="AI推理计算单元&lt;br&gt;专用ASIC | 矩阵运算优化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;" vertex="1" parent="track_ai">
          <mxGeometry x="120" y="270" width="340" height="70" as="geometry" />
